{
    "name": "@monk-api/os",
    "version": "0.2.0",
    "description": "A Plan 9/BeOS-inspired operating system where Bun is the hardware",
    "type": "module",
    "main": "src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./*": "./src/*"
    },
    "scripts": {
        "start": "bun src/boot.ts",
        "start:sqlite": "bun src/boot.ts --sqlite",
        "build": "scripts/build.sh",
        "build:warn": "scripts/build-warn.sh",
        "build:standalone": "scripts/build-standalone.sh",
        "test": "bun test --preload ./spec/bun-test-setup.ts spec",
        "test:coverage": "bun test --coverage --preload ./spec/bun-test-setup.ts spec",
        "perf": "bun test --preload ./spec/bun-test-setup.ts ./perf/**/*.perf.ts",
        "perf:coverage": "bun test --coverage --preload ./spec/bun-test-setup.ts ./perf/**/*.perf.ts",
        "perf:fixtures": "bun run ./perf/fixtures.ts",
        "typecheck": "bun x tsc --noEmit",
        "typecheck:spec": "bun x tsc --noEmit -p tsconfig.spec.json",
        "typecheck:perf": "bun x tsc --noEmit -p tsconfig.perf.json"
    },
    "keywords": [
        "os",
        "kernel",
        "vfs",
        "bun",
        "typescript"
    ],
    "author": "Ian Zepp",
    "license": "SEE LICENSE IN LICENSE.md",
    "devDependencies": {
        "@types/bun": "^1.3.3",
        "typescript": "^5.6.3"
    },
    "engines": {
        "bun": ">=1.0.0"
    },
    "dependencies": {
        "acorn": "^8.15.0",
        "acorn-loose": "^8.5.2"
    }
}
