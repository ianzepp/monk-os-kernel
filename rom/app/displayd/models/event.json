{
    "description": "Input event from browser",
    "passthrough": true,
    "fields": {
        "display_id": {
            "type": "uuid",
            "required": true,
            "indexed": "simple",
            "description": "Source display"
        },
        "window_id": {
            "type": "uuid",
            "indexed": "simple",
            "description": "Target window"
        },
        "element_id": {
            "type": "uuid",
            "indexed": "simple",
            "description": "Target element"
        },
        "type": {
            "type": "text",
            "required": true,
            "indexed": "simple",
            "description": "Event type"
        },
        "data": {
            "type": "jsonb",
            "description": "Event-specific data"
        },
        "timestamp": {
            "type": "integer",
            "required": true,
            "indexed": "simple",
            "description": "Event timestamp (Unix ms)"
        },
        "target_tag": {
            "type": "text",
            "description": "Target element tag name"
        },
        "key": {
            "type": "text",
            "indexed": "simple",
            "description": "Key pressed"
        },
        "button": {
            "type": "integer",
            "description": "Mouse button"
        },
        "x": {
            "type": "integer",
            "description": "X coordinate"
        },
        "y": {
            "type": "integer",
            "description": "Y coordinate"
        },
        "shift": {
            "type": "boolean",
            "description": "Shift key held"
        },
        "ctrl": {
            "type": "boolean",
            "description": "Control key held"
        },
        "alt": {
            "type": "boolean",
            "description": "Alt key held"
        },
        "meta": {
            "type": "boolean",
            "description": "Meta/Command key held"
        },
        "handled": {
            "type": "boolean",
            "indexed": "simple",
            "description": "Event has been processed"
        },
        "prevented": {
            "type": "boolean",
            "description": "Default action prevented"
        }
    }
}
