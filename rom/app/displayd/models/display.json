{
    "description": "Browser display session",
    "passthrough": false,
    "fields": {
        "width": {
            "type": "integer",
            "required": true,
            "description": "Screen width in pixels"
        },
        "height": {
            "type": "integer",
            "required": true,
            "description": "Screen height in pixels"
        },
        "dpi": {
            "type": "numeric",
            "default_value": "1",
            "description": "Device pixel ratio"
        },
        "connected": {
            "type": "boolean",
            "description": "Browser currently connected"
        },
        "session_id": {
            "type": "text",
            "description": "Browser session identifier"
        },
        "user_agent": {
            "type": "text",
            "description": "Browser user agent string"
        },
        "last_ping": {
            "type": "timestamp",
            "description": "Last heartbeat from browser"
        }
    }
}
