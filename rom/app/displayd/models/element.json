{
    "description": "UI element within a window",
    "passthrough": true,
    "fields": {
        "window_id": {
            "type": "uuid",
            "required": true,
            "index": true,
            "relationship_type": "owned",
            "related_model": "window",
            "cascade_delete": true,
            "description": "Parent window"
        },
        "parent_id": {
            "type": "uuid",
            "index": true,
            "description": "Parent element (null = window root)"
        },
        "tag": {
            "type": "text",
            "required": true,
            "default_value": "div",
            "description": "HTML tag name"
        },
        "props": {
            "type": "jsonb",
            "description": "Element properties"
        },
        "text": {
            "type": "text",
            "description": "Text content"
        },
        "order": {
            "type": "integer",
            "default_value": "0",
            "description": "Sibling order"
        },
        "flex": {
            "type": "text",
            "description": "Flex shorthand"
        },
        "width": {
            "type": "text",
            "description": "CSS width value"
        },
        "height": {
            "type": "text",
            "description": "CSS height value"
        },
        "disabled": {
            "type": "boolean",
            "default_value": "0",
            "description": "Element is disabled"
        },
        "hidden": {
            "type": "boolean",
            "default_value": "0",
            "index": true,
            "description": "Element is hidden"
        },
        "value": {
            "type": "text",
            "description": "Current input value"
        },
        "placeholder": {
            "type": "text",
            "description": "Placeholder text"
        },
        "tabindex": {
            "type": "integer",
            "description": "Tab order"
        },
        "autofocus": {
            "type": "boolean",
            "default_value": "0",
            "description": "Auto-focus on mount"
        }
    }
}
