{
    "description": "Short-term memory - raw experiences awaiting consolidation",
    "passthrough": false,
    "fields": {
        "content": {
            "type": "text",
            "required": true,
            "description": "Raw memory content"
        },
        "context": {
            "type": "jsonb",
            "description": "Context data (task_id, source, etc.)"
        },
        "salience": {
            "type": "integer",
            "required": true,
            "default_value": "5",
            "indexed": "simple",
            "description": "Salience 1-9 (1=trivial, 9=critical)"
        },
        "consolidated": {
            "type": "boolean",
            "required": true,
            "default_value": "0",
            "indexed": "simple",
            "description": "Has been processed during consolidation"
        },
        "consolidated_at": {
            "type": "timestamp",
            "description": "When consolidation occurred"
        }
    }
}
