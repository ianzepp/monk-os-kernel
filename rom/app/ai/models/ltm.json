{
    "description": "Long-term memory - consolidated knowledge and insights",
    "passthrough": false,
    "fields": {
        "content": {
            "type": "text",
            "required": true,
            "description": "Consolidated memory content"
        },
        "category": {
            "type": "text",
            "indexed": "simple",
            "description": "Memory category (user_prefs, project_facts, lessons, etc.)"
        },
        "source_ids": {
            "type": "jsonb",
            "description": "Array of source STM ids"
        },
        "reinforced": {
            "type": "integer",
            "required": true,
            "default_value": "1",
            "indexed": "simple",
            "description": "Reinforcement count (higher = stronger)"
        },
        "last_accessed": {
            "type": "timestamp",
            "indexed": "simple",
            "description": "Last retrieval timestamp (for decay)"
        }
    }
}
